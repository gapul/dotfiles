{
  "$help": "https://aka.ms/terminal-documentation",
  "$schema": "https://aka.ms/terminal-profiles-schema",
  "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
  "copyOnSelect": false,
  "copyFormatting": "none",
  "useAcrylicInTabRow": false,
  "alwaysShowTabs": true,
  "showTerminalTitleInTitlebar": true,
  "theme": "system",
  "profiles": {
    "defaults": {
      "fontFace": "HackGen Console NF",
      "fontSize": 12,
      "antialiasingMode": "cleartype",
      "cursorShape": "filledBox",
      "scrollbarState": "hidden",
      "experimental.retroTerminalEffect": false,
      "padding": "8",
      "colorScheme": "Rose Pine (dotfiles)"
    },
    "list": [
      {
        "guid": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
        "name": "PowerShell 7",
        "commandline": "pwsh.exe -NoLogo",
        "icon": "ms-appx:///ProfileIcons/{574e775e-4f2a-5b96-ac1e-a2962a402336}.png",
        "startingDirectory": "%USERPROFILE%",
        "hidden": false
      },
      {
        "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
        "name": "Windows PowerShell 5.1",
        "commandline": "powershell.exe -NoLogo",
        "startingDirectory": "%USERPROFILE%",
        "hidden": false
      },
      {
        "guid": "{2c4de342-38b7-51cf-b940-2309a097f518}",
        "name": "Ubuntu (WSL)",
        "source": "Windows.Terminal.Wsl",
        "icon": "ms-appx:///ProfileIcons/{9acb9455-ca41-5af7-950f-6bca1bc9722f}.png",
        "startingDirectory": "//wsl$/__WSL_DISTRO__/home/__WSL_USER__"
      },
      {
        "guid": "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}",
        "name": "Command Prompt",
        "hidden": true
      }
    ]
  },
  "schemes": [
    {
      "name": "Rose Pine (dotfiles)",
      "background":          "{{ palette.base }}",
      "foreground":          "{{ palette.text }}",
      "cursorColor":         "{{ palette.iris }}",
      "selectionBackground": "{{ palette.hlMed }}",
      "black":               "{{ palette.overlay }}",
      "red":                 "{{ palette.love }}",
      "green":               "{{ palette.pine }}",
      "yellow":              "{{ palette.gold }}",
      "blue":                "{{ palette.foam }}",
      "purple":              "{{ palette.iris }}",
      "cyan":                "{{ palette.rose }}",
      "white":               "{{ palette.text }}",
      "brightBlack":         "{{ palette.muted }}",
      "brightRed":           "{{ palette.love }}",
      "brightGreen":         "{{ palette.pine }}",
      "brightYellow":        "{{ palette.gold }}",
      "brightBlue":          "{{ palette.foam }}",
      "brightPurple":        "{{ palette.iris }}",
      "brightCyan":          "{{ palette.rose }}",
      "brightWhite":         "{{ palette.text }}"
    }
  ],
  "actions": [
    { "command": { "action": "copy", "singleLine": false }, "keys": "ctrl+shift+c" },
    { "command": "paste", "keys": "ctrl+shift+v" },
    { "command": "find", "keys": "ctrl+shift+f" },
    { "command": { "action": "splitPane", "split": "auto", "splitMode": "duplicate" }, "keys": "alt+shift+d" }
  ]
}
