{
  "name": "Dotfiles Management System",
  "description": "Secure and comprehensive macOS dotfiles management system with symlink-based configuration management",
  "version": "1.0.0",
  "keywords": ["dotfiles", "macos", "shell", "configuration", "automation"],
  "commands": {
    "install": "./install.sh",
    "install-force": "./install.sh --force", 
    "setup": "./setup.sh",
    "backup-list": "./install.sh --list-backups",
    "backup-cleanup": "./install.sh --cleanup-backups",
    "validate": "python3 .github/scripts/validate_toml.py",
    "check-ci": "./check-ci.sh",
    "lint-shell": "shellcheck *.sh",
    "nvim-health": "nvim +checkhealth +qall"
  },
  "scripts": {
    "test": "python3 .github/scripts/validate_toml.py && shellcheck *.sh",
    "bootstrap": "./setup.sh && ./install.sh",
    "update-nvim": "nvim +Lazy! sync +qall"
  },
  "environments": {
    "development": {
      "DOTFILES_DIR": "$(pwd)",
      "DEBUG": "true"
    },
    "production": {
      "DOTFILES_DIR": "$(pwd)",
      "DEBUG": "false"
    }
  }
}