# SSH Configuration Example File
# IMPORTANT: This is a template file. 
# Copy this file to 'config' (without extension) and customize for your environment.
# The actual 'config' file is excluded from version control for security reasons.

Host github github.com
  HostName github.com
  IdentityFile ~/.ssh/id_rsa  # or ~/.ssh/id_ed25519
  User git

# Example: Custom server configuration
# Host myserver
#   HostName your-server.com
#   IdentityFile ~/.ssh/id_rsa
#   User your-username
#   Port 22