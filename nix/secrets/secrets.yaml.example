# Example secrets file for sops-nix
# This file shows the structure for encrypted secrets
#
# To create an actual encrypted secrets file:
# 1. Copy this file to secrets.yaml
# 2. Run: sops nix/secrets/secrets.yaml
# 3. Edit the file in your editor to add real secrets
# 4. Save and exit - sops will encrypt the file

# Development secrets
development:
  api_key: "your-api-key-here"
  database_password: "your-db-password"
  jwt_secret: "your-jwt-secret"
  
# AI platform secrets  
ai_platform:
  openai_api_key: "sk-your-openai-key"
  anthropic_api_key: "your-anthropic-key"
  github_token: "ghp_your-github-token"
  
# System secrets
system:
  wifi_password: "your-wifi-password"
  backup_encryption_key: "your-backup-key"
  
# Cloud provider secrets
cloud:
  aws_access_key: "AKIA..."
  aws_secret_key: "your-aws-secret"
  gcp_service_account: "your-gcp-key.json"