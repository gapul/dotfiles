# SOPS Secrets Template for macOS (Darwin)
# Platform-specific secrets for macOS systems

# macOS-specific secrets
macos:
  keychain_password: ENC[AES256_GCM,data:EXAMPLE_ENCRYPTED_KEYCHAIN_PASSWORD,type:str]
  
# HomebrewGitHub API Token (for private taps)
homebrew:
  github_token: ENC[AES256_GCM,data:EXAMPLE_ENCRYPTED_HOMEBREW_TOKEN,type:str]

# macOS-specific development tools
dev:
  xcode_select_path: /Applications/Xcode.app/Contents/Developer
  apple_team_id: ENC[AES256_GCM,data:EXAMPLE_ENCRYPTED_TEAM_ID,type:str]

# SOPS metadata
sops:
  age:
    - recipient: age1darwin123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
      enc: |
        -----BEGIN AGE ENCRYPTED FILE-----
        YWdlLWVuY3J5cHRpb24ub3JnL3YxCi0+IFgyNTUxOSBEYXJ3aW5LZXlEYXRh
        -----END AGE ENCRYPTED FILE-----
  gcp_kms: []
  azure_kv: []
  hc_vault: []
  lastmodified: '2025-06-17T16:00:00Z'
  mac: ENC[AES256_GCM,data:EXAMPLE_MAC_VALUE_DARWIN,type:str]
  pgp: []
  version: 3.8.1
EOF < /dev/null