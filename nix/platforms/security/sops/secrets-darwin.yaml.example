# SOPS Secrets Template - macOS Specific
# Platform-specific secrets for macOS environments

# macOS-specific secrets
macos:
    keychain_password: ENC[AES256_GCM,data:example_encrypted_keychain_password,iv:example_iv,tag:example_tag,type:str]
    
# Development environment
dev:
    homebrew_token: ENC[AES256_GCM,data:example_encrypted_homebrew_token,iv:example_iv,tag:example_tag,type:str]
    xcode_license: ENC[AES256_GCM,data:example_encrypted_xcode_license,iv:example_iv,tag:example_tag,type:str]

# Cloud services (macOS-specific configurations)
cloud:
    icloud_keychain: ENC[AES256_GCM,data:example_encrypted_icloud_config,iv:example_iv,tag:example_tag,type:str]

# Metadata
sops:
    kms: []
    gcp_kms: []
    azure_kv: []
    hc_vault: []
    age:
        - recipient: age1hl8rkwqkp6l7f5zxc9hjn8m5v3k9p4q7x6z2r8t4w5u6y7i8o9p0q1r2s3t4u5v6
          enc: example_encrypted_key
    lastmodified: "2025-06-17T06:30:00Z"
    mac: example_mac
    pgp: []
    unencrypted_suffix: _unencrypted
    version: 3.8.1