# SOPS Secrets Template
# This is an example file showing the structure for encrypted secrets
# Copy this file to secrets.yaml and add your actual secrets

# GitHub integration secrets
github:
  token: ENC[AES256_GCM,data:EXAMPLE_ENCRYPTED_DATA,type:str]

# SSH keys
ssh:
  personal_key: ENC[AES256_GCM,data:EXAMPLE_ENCRYPTED_PRIVATE_KEY,type:str]
  personal_key_pub: ENC[AES256_GCM,data:EXAMPLE_ENCRYPTED_PUBLIC_KEY,type:str]

# API credentials
api:
  openai_key: ENC[AES256_GCM,data:EXAMPLE_ENCRYPTED_API_KEY,type:str]
  anthropic_key: ENC[AES256_GCM,data:EXAMPLE_ENCRYPTED_API_KEY,type:str]

# Git configuration
git:
  signing_key: ENC[AES256_GCM,data:EXAMPLE_ENCRYPTED_SIGNING_KEY,type:str]

# Development tools
dev:
  npm_token: ENC[AES256_GCM,data:EXAMPLE_ENCRYPTED_NPM_TOKEN,type:str]

# SOPS metadata (required for encryption)
sops:
  age:
    - recipient: age1example123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
      enc: |
        -----BEGIN AGE ENCRYPTED FILE-----
        YWdlLWVuY3J5cHRpb24ub3JnL3YxCi0+IFgyNTUxOSBFeGFtcGxlS2V5RGF0YQ==
        -----END AGE ENCRYPTED FILE-----
  gcp_kms: []
  azure_kv: []
  hc_vault: []
  lastmodified: '2025-06-17T16:00:00Z'
  mac: ENC[AES256_GCM,data:EXAMPLE_MAC_VALUE,type:str]
  pgp: []
  version: 3.8.1
EOF < /dev/null