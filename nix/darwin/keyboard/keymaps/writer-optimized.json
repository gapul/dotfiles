{
  "version": 1,
  "notes": "Writer-optimized keymap focused on text editing and document creation",
  "keyboard": "generic",
  "keymap": "writer-optimized",
  "layout": "LAYOUT",
  "author": "Dotfiles System",
  "description": "Keymap optimized for writers with text editing shortcuts and writing tools",
  "layers": [
    {
      "name": "Base Writing Layer",
      "description": "Standard QWERTY with writing-focused modifications",
      "keys": [
        "KC_TAB",    "KC_Q",    "KC_W",    "KC_E",    "KC_R",    "KC_T",    "KC_Y",    "KC_U",    "KC_I",    "KC_O",    "KC_P",    "KC_BSPC",
        "LCTL_T(KC_ESC)", "KC_A", "KC_S",    "KC_D",    "KC_F",    "KC_G",    "KC_H",    "KC_J",    "KC_K",    "KC_L",    "KC_SCLN", "KC_QUOT",
        "KC_LSFT",   "KC_Z",    "KC_X",    "KC_C",    "KC_V",    "KC_B",    "KC_N",    "KC_M",    "KC_COMM", "KC_DOT",  "KC_SLSH", "KC_ENT",
        "KC_LGUI",   "KC_LALT", "KC_LCTL", "KC_SPC",  "LT(1, KC_SPC)", "KC_RCTL", "KC_RALT", "KC_RGUI"
      ],
      "features": {
        "standardQwerty": true,
        "homeRowMods": true,
        "layerTaps": true,
        "writingOptimized": true
      }
    },
    {
      "name": "Text Editing Layer",
      "description": "Text editing shortcuts and formatting tools",
      "keys": [
        "KC_TRNS",   "LCTL(KC_Q)", "LCTL(KC_W)", "LCTL(KC_E)", "LCTL(KC_R)", "LCTL(KC_T)", "LCTL(KC_Y)", "LCTL(KC_U)", "LCTL(KC_I)", "LCTL(KC_O)", "LCTL(KC_P)", "KC_DEL",
        "KC_TRNS",   "LCTL(KC_A)", "LCTL(KC_S)", "LCTL(KC_D)", "LCTL(KC_F)", "LCTL(KC_G)", "LCTL(KC_H)", "LCTL(KC_J)", "LCTL(KC_K)", "LCTL(KC_L)", "KC_TRNS", "KC_TRNS",
        "KC_TRNS",   "LCTL(KC_Z)", "LCTL(KC_X)", "LCTL(KC_C)", "LCTL(KC_V)", "LCTL(KC_B)", "LCTL(KC_N)", "LCTL(KC_M)", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS",
        "KC_TRNS",   "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS"
      ],
      "features": {
        "textShortcuts": true,
        "formatting": true,
        "documentControl": true
      }
    },
    {
      "name": "Navigation & Selection",
      "description": "Document navigation and text selection",
      "keys": [
        "KC_F1",     "KC_F2",   "KC_F3",   "KC_F4",   "KC_F5",   "KC_F6",   "KC_F7",   "KC_F8",   "KC_F9",   "KC_F10",  "KC_F11",  "KC_F12",
        "KC_TRNS",   "KC_HOME", "KC_PGDN", "KC_PGUP", "KC_END",  "LCTL(KC_F)", "KC_LEFT", "KC_DOWN", "KC_UP",   "KC_RGHT", "LCTL(KC_G)", "KC_TRNS",
        "KC_TRNS",   "LSFT(KC_HOME)", "LSFT(KC_PGDN)", "LSFT(KC_PGUP)", "LSFT(KC_END)", "KC_TRNS", "LSFT(KC_LEFT)", "LSFT(KC_DOWN)", "LSFT(KC_UP)", "LSFT(KC_RGHT)", "KC_TRNS", "KC_TRNS",
        "KC_TRNS",   "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS"
      ],
      "features": {
        "navigationKeys": true,
        "textSelection": true,
        "findReplace": true,
        "pageNavigation": true
      }
    },
    {
      "name": "Writing Tools & System",
      "description": "Writing tools, media controls, and system functions",
      "keys": [
        "QK_BOOT",   "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "QK_CLEAR_EEPROM",
        "RGB_TOG",   "RGB_HUI", "RGB_SAI", "RGB_VAI", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_VOLD", "KC_VOLU", "KC_MUTE", "KC_TRNS", "KC_TRNS",
        "RGB_MOD",   "RGB_HUD", "RGB_SAD", "RGB_VAD", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_MPRV", "KC_MNXT", "KC_MPLY", "KC_TRNS", "KC_TRNS",
        "KC_TRNS",   "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS"
      ],
      "features": {
        "mediaKeys": true,
        "rgbControls": true,
        "systemControls": true,
        "writingModes": true
      }
    }
  ],
  "macros": [
    {
      "name": "Lorem Ipsum",
      "keys": ["KC_L", "KC_O", "KC_R", "KC_E", "KC_M", "KC_SPC", "KC_I", "KC_P", "KC_S", "KC_U", "KC_M", "KC_SPC", "KC_D", "KC_O", "KC_L", "KC_O", "KC_R", "KC_SPC", "KC_S", "KC_I", "KC_T", "KC_SPC", "KC_A", "KC_M", "KC_E", "KC_T"],
      "description": "Types Lorem ipsum placeholder text"
    },
    {
      "name": "Email Signature",
      "keys": ["KC_ENT", "KC_ENT", "KC_B", "KC_E", "KC_S", "KC_T", "KC_SPC", "KC_R", "KC_E", "KC_G", "KC_A", "KC_R", "KC_D", "KC_S", "KC_COMM", "KC_ENT"],
      "description": "Types email signature template"
    },
    {
      "name": "Date Stamp",
      "keys": ["LCTL(KC_SCLN)"],
      "description": "Inserts current date (application dependent)"
    },
    {
      "name": "Word Count",
      "keys": ["LCTL(KC_LSFT)", "KC_C"],
      "description": "Opens word count dialog (application dependent)"
    }
  ],
  "tapDance": [
    {
      "name": "Period/Ellipsis",
      "keys": ["KC_DOT", "KC_DOT", "KC_DOT"],
      "description": "Tap for period, double-tap for ellipsis"
    },
    {
      "name": "Comma/Semicolon",
      "keys": ["KC_COMM", "KC_SCLN"],
      "description": "Tap for comma, double-tap for semicolon"
    }
  ],
  "combos": [
    {
      "name": "Em Dash",
      "keys": ["KC_MINS", "KC_MINS"],
      "result": "UC(0x2014)",
      "description": "Double minus for em dash"
    },
    {
      "name": "Smart Quote Open",
      "keys": ["KC_QUOT", "KC_LSFT"],
      "result": "UC(0x201C)",
      "description": "Smart opening quote"
    },
    {
      "name": "Smart Quote Close",
      "keys": ["KC_QUOT", "KC_RSFT"],
      "result": "UC(0x201D)",
      "description": "Smart closing quote"
    }
  ],
  "settings": {
    "tappingTerm": 180,
    "permissiveHold": true,
    "ignoreMod": false,
    "tapDanceEager": false,
    "comboTerm": 30,
    "mouseKeys": false,
    "unicodeInput": true,
    "autoShift": true,
    "autoShiftTimeout": 175
  },
  "rgbSettings": {
    "defaultMode": "RGB_MODE_BREATHING",
    "brightness": 100,
    "hue": 170,
    "saturation": 200,
    "speed": 100,
    "layerIndication": true,
    "capsLockIndication": true,
    "writingModeColors": {
      "focus": {"hue": 200, "saturation": 255},
      "creative": {"hue": 300, "saturation": 200},
      "editing": {"hue": 60, "saturation": 180}
    }
  },
  "audioSettings": {
    "enable": false,
    "startupSound": false,
    "layerSounds": false,
    "clickSound": false,
    "musicMode": false,
    "writingAmbient": false
  },
  "writingFeatures": {
    "focusMode": true,
    "distractionFree": true,
    "wordCountDisplay": true,
    "typingMetrics": true,
    "breakReminders": true,
    "goalTracking": true
  }
}