{
  "version": 1,
  "notes": "Developer-optimized keymap with programming symbols and shortcuts",
  "keyboard": "generic",
  "keymap": "developer-base",
  "layout": "LAYOUT",
  "author": "Dotfiles System",
  "description": "Base developer keymap template with 4 layers optimized for programming workflow",
  "layers": [
    {
      "name": "Base Layer",
      "description": "Main typing layer with programming optimizations",
      "keys": [
        "KC_TAB",    "KC_Q",    "KC_W",    "KC_E",    "KC_R",    "KC_T",    "KC_Y",    "KC_U",    "KC_I",    "KC_O",    "KC_P",    "KC_BSPC",
        "LCTL_T(KC_ESC)", "KC_A", "KC_S",    "KC_D",    "KC_F",    "KC_G",    "KC_H",    "KC_J",    "KC_K",    "KC_L",    "KC_SCLN", "KC_QUOT",
        "KC_LSFT",   "KC_Z",    "KC_X",    "KC_C",    "KC_V",    "KC_B",    "KC_N",    "KC_M",    "KC_COMM", "KC_DOT",  "KC_SLSH", "KC_ENT",
        "KC_LGUI",   "KC_LALT", "KC_LCTL", "LT(1, KC_SPC)", "LT(2, KC_SPC)", "KC_RCTL", "KC_RALT", "KC_RGUI"
      ],
      "features": {
        "homeRowMods": true,
        "layerTaps": true,
        "escapeControl": true
      }
    },
    {
      "name": "Symbols Layer",
      "description": "Programming symbols, numbers, and operators",
      "keys": [
        "KC_GRV",    "KC_1",    "KC_2",    "KC_3",    "KC_4",    "KC_5",    "KC_6",    "KC_7",    "KC_8",    "KC_9",    "KC_0",    "KC_DEL",
        "KC_TRNS",   "KC_EXLM", "KC_AT",   "KC_HASH", "KC_DLR",  "KC_PERC", "KC_CIRC", "KC_AMPR", "KC_ASTR", "KC_LPRN", "KC_RPRN", "KC_PIPE",
        "KC_TRNS",   "KC_TILD", "KC_UNDS", "KC_PLUS", "KC_LCBR", "KC_RCBR", "KC_LBRC", "KC_RBRC", "KC_MINS", "KC_EQL",  "KC_BSLS", "KC_TRNS",
        "KC_TRNS",   "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS"
      ],
      "features": {
        "programmingSymbols": true,
        "numberRow": true,
        "brackets": true
      }
    },
    {
      "name": "Navigation Layer",
      "description": "Arrow keys, function keys, and navigation shortcuts",
      "keys": [
        "KC_F1",     "KC_F2",   "KC_F3",   "KC_F4",   "KC_F5",   "KC_F6",   "KC_F7",   "KC_F8",   "KC_F9",   "KC_F10",  "KC_F11",  "KC_F12",
        "KC_TRNS",   "KC_HOME", "KC_PGDN", "KC_PGUP", "KC_END",  "KC_TRNS", "KC_LEFT", "KC_DOWN", "KC_UP",   "KC_RGHT", "KC_TRNS", "KC_TRNS",
        "KC_TRNS",   "LCTL(KC_Z)", "LCTL(KC_X)", "LCTL(KC_C)", "LCTL(KC_V)", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS",
        "KC_TRNS",   "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS"
      ],
      "features": {
        "functionKeys": true,
        "arrowKeys": true,
        "shortcuts": true,
        "navigation": true
      }
    },
    {
      "name": "System Layer",
      "description": "Media keys, RGB controls, and system functions",
      "keys": [
        "QK_BOOT",   "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "QK_CLEAR_EEPROM",
        "RGB_TOG",   "RGB_HUI", "RGB_SAI", "RGB_VAI", "RGB_SPI", "KC_TRNS", "KC_TRNS", "KC_VOLD", "KC_VOLU", "KC_MUTE", "KC_TRNS", "KC_TRNS",
        "RGB_MOD",   "RGB_HUD", "RGB_SAD", "RGB_VAD", "RGB_SPD", "KC_TRNS", "KC_TRNS", "KC_MPRV", "KC_MNXT", "KC_MPLY", "KC_TRNS", "KC_TRNS",
        "KC_TRNS",   "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS", "KC_TRNS"
      ],
      "features": {
        "rgbControls": true,
        "mediaKeys": true,
        "systemControls": true,
        "bootloader": true
      }
    }
  ],
  "macros": [
    {
      "name": "Git Status",
      "keys": ["KC_G", "KC_I", "KC_T", "KC_SPC", "KC_S", "KC_T", "KC_A", "KC_T", "KC_U", "KC_S", "KC_ENT"],
      "description": "Types 'git status' and presses enter"
    },
    {
      "name": "Console Log",
      "keys": ["KC_C", "KC_O", "KC_N", "KC_S", "KC_O", "KC_L", "KC_E", "KC_DOT", "KC_L", "KC_O", "KC_G", "KC_LPRN", "KC_RPRN", "KC_LEFT"],
      "description": "Types 'console.log()' and positions cursor inside parentheses"
    },
    {
      "name": "Arrow Function",
      "keys": ["KC_LPRN", "KC_RPRN", "KC_SPC", "KC_EQL", "KC_GT", "KC_SPC", "KC_LCBR", "KC_ENT", "KC_ENT", "KC_RCBR", "KC_UP", "KC_UP", "KC_END"],
      "description": "Creates arrow function template"
    }
  ],
  "tapDance": [
    {
      "name": "Shift/Caps",
      "keys": ["KC_LSFT", "KC_CAPS"],
      "description": "Tap for shift, double-tap for caps lock"
    },
    {
      "name": "Quote/Double Quote",
      "keys": ["KC_QUOT", "KC_DQUO"],
      "description": "Tap for single quote, double-tap for double quote"
    }
  ],
  "combos": [
    {
      "name": "Escape",
      "keys": ["KC_J", "KC_K"],
      "result": "KC_ESC",
      "description": "JK combo for escape"
    },
    {
      "name": "Delete",
      "keys": ["KC_H", "KC_L"],
      "result": "KC_DEL",
      "description": "HL combo for delete"
    }
  ],
  "settings": {
    "tappingTerm": 200,
    "permissiveHold": true,
    "ignoreMod": false,
    "tapDanceEager": true,
    "comboTerm": 50,
    "mouseKeys": false,
    "unicodeInput": false,
    "autoShift": false
  },
  "rgbSettings": {
    "defaultMode": "RGB_MODE_RAINBOW_SWIRL",
    "brightness": 128,
    "hue": 0,
    "saturation": 255,
    "speed": 127,
    "layerIndication": true,
    "capsLockIndication": true,
    "lowBatteryIndication": true
  },
  "audioSettings": {
    "enable": true,
    "startupSound": true,
    "layerSounds": false,
    "clickSound": false,
    "musicMode": false
  }
}