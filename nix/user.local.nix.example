# Lab PC / 出先など、Mac の `yuki` と違う OS user 名を持つ環境用の override。
# このファイルを `nix/user.local.nix` (拡張子 .example を外す) にコピーして
# username 等を書き換える。`.gitignore` に追加してあるので commit されない。
#
# 使い方:
#   cp nix/user.local.nix.example nix/user.local.nix
#   nvim nix/user.local.nix    # username を実機の OS user に
#   nix run github:nix-community/home-manager -- switch --flake ~/.dotfiles/nix#labpc-wsl
{
  # WSL / Linux の OS username に揃える (whoami と一致する必要)
  username = "REPLACE_ME";

  # 必要なら他の項目も上書き可:
  # gitUser  = "gapul";
  # gitEmail = "92638132+gapul@users.noreply.github.com";
}
