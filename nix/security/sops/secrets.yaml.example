# SOPS secrets configuration example
# This file demonstrates the structure for managing secrets with sops-nix
# 
# To use this file:
# 1. Copy to secrets.yaml: cp secrets.yaml.example secrets.yaml
# 2. Generate age key: age-keygen -o ~/.config/sops/age/keys.txt
# 3. Encrypt with age: sops -e -a $(cat ~/.config/sops/age/keys.txt | grep public | cut -d: -f2 | tr -d ' ') secrets.yaml
#
# Note: The actual secrets.yaml file is excluded from git via .gitignore

# GitHub integration secrets
github_token: "ghp_your_github_personal_access_token_here"
github_ssh_key: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  your_github_ssh_private_key_content_here
  -----END OPENSSH PRIVATE KEY-----

# OpenAI API configuration
openai_api_key: "sk-your_openai_api_key_here"

# Development environment secrets
claude_api_key: "your_claude_api_key_here"
anthropic_api_key: "your_anthropic_api_key_here"

# Email configuration
email_password: "your_email_app_specific_password"
smtp_username: "your_smtp_username"
smtp_password: "your_smtp_password"

# Database credentials (for development)
postgres_password: "your_postgres_password"
redis_password: "your_redis_password"

# Cloud service keys
aws_access_key_id: "your_aws_access_key"
aws_secret_access_key: "your_aws_secret_access_key"
gcp_service_account_key: |
  {
    "type": "service_account",
    "project_id": "your-project-id",
    "private_key_id": "your-key-id",
    "private_key": "-----BEGIN PRIVATE KEY-----\nyour-private-key\n-----END PRIVATE KEY-----\n",
    "client_email": "your-service-account@your-project.iam.gserviceaccount.com",
    "client_id": "your-client-id",
    "auth_uri": "https://accounts.google.com/o/oauth2/auth",
    "token_uri": "https://oauth2.googleapis.com/token"
  }

# Application-specific secrets
discord_bot_token: "your_discord_bot_token"
slack_webhook_url: "https://hooks.slack.com/services/your/webhook/url"

# SSH configuration
ssh_config: |
  # Private SSH configuration
  Host private-server
    HostName your-server.example.com
    User your-username
    IdentityFile ~/.ssh/id_rsa
    Port 22

# Environment variables for development
dev_environment:
  DATABASE_URL: "postgresql://user:password@localhost/dbname"
  REDIS_URL: "redis://localhost:6379"
  API_BASE_URL: "https://api.example.com"
  JWT_SECRET: "your_jwt_secret_key"

# License keys
license_keys:
  jetbrains: "your_jetbrains_license_key"
  parallels: "your_parallels_license_key"