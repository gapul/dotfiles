# SOPS Unified Secrets Template
# ALL SECRETS MANAGED THROUGH SOPS - Git-crypt DEPRECATED
# This file replaces all previous encryption methods
#
# Setup:
#   1. cp secrets-unified.yaml.example secrets-unified.yaml
#   2. age-keygen -o ~/.config/sops/age/keys.txt
#   3. export SOPS_AGE_RECIPIENTS="$(age-keygen -y ~/.config/sops/age/keys.txt)"
#   4. sops -e -i secrets-unified.yaml
#   5. sops secrets-unified.yaml  # Edit encrypted file
#
# This file contains ALL secrets previously managed by:
# - Git-crypt encrypted files
# - .gitignore excluded files  
# - Manual secret management

# API Keys and Tokens
api:
  github_token: "ghp_your_github_personal_access_token"
  openai_key: "sk-your_openai_api_key"
  anthropic_key: "your_anthropic_claude_api_key"
  npm_token: "npm_your_registry_token"

# Git Configuration Secrets
git:
  signing_key_id: "your_gpg_key_id_for_commits"
  signing_key_private: |
    -----BEGIN PGP PRIVATE KEY BLOCK-----
    your_gpg_private_key_content_here
    -----END PGP PRIVATE KEY BLOCK-----

# SSH Keys and Configuration
ssh:
  private_key: |
    -----BEGIN OPENSSH PRIVATE KEY-----
    your_ssh_private_key_content_here
    -----END OPENSSH PRIVATE KEY-----
  public_key: "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5... your@email.com"
  config: |
    # SSH Configuration
    Host github.com
        HostName github.com
        User git
        IdentityFile ~/.ssh/id_ed25519
        
    Host your-server
        HostName your.server.example.com
        User your_username
        Port 22
        IdentityFile ~/.ssh/id_ed25519

# SSL/TLS Certificates
ssl:
  certificate: |
    -----BEGIN CERTIFICATE-----
    your_ssl_certificate_content_here
    -----END CERTIFICATE-----
  private_key: |
    -----BEGIN PRIVATE KEY-----
    your_ssl_private_key_content_here
    -----END PRIVATE KEY-----

# Development Environment Secrets
development:
  env_vars:
    DATABASE_PASSWORD: "your_database_password"
    REDIS_PASSWORD: "your_redis_password"
    JWT_SECRET: "your_jwt_secret_key"
    ENCRYPTION_KEY: "your_app_encryption_key"
  
  config_files:
    npmrc: |
      //registry.npmjs.org/:_authToken=your_npm_token
      @your-scope:registry=https://npm.pkg.github.com/
      //npm.pkg.github.com/:_authToken=your_github_token
    
    docker_config: |
      {
        "auths": {
          "https://index.docker.io/v1/": {
            "auth": "your_docker_auth_base64"
          }
        }
      }

# Cloud Provider Credentials
cloud:
  aws:
    access_key_id: "AKIA..."
    secret_access_key: "your_aws_secret_key"
    region: "us-west-2"
  
  gcp:
    service_account_key: |
      {
        "type": "service_account",
        "project_id": "your-project",
        "private_key_id": "key_id",
        "private_key": "-----BEGIN PRIVATE KEY-----\nyour_gcp_private_key\n-----END PRIVATE KEY-----\n",
        "client_email": "your-service@your-project.iam.gserviceaccount.com"
      }

# Platform-specific Secrets
macos:
  keychain_password: "your_keychain_password"
  app_store_password: "your_app_specific_password"

linux:
  sudo_password: "your_sudo_password"
  gpg_passphrase: "your_gpg_passphrase"

android:
  termux_token: "your_termux_api_token"
  fdroid_key: "your_fdroid_signing_key"

# Database Credentials
databases:
  postgresql:
    host: "your.postgres.host.com"
    port: 5432
    database: "your_database_name"
    username: "your_db_username"
    password: "your_db_password"
  
  mysql:
    host: "your.mysql.host.com"
    port: 3306
    database: "your_database_name"
    username: "your_db_username"
    password: "your_db_password"

# Monitoring and Logging
monitoring:
  grafana_admin_password: "your_grafana_admin_password"
  prometheus_basic_auth: "username:password_hash"
  elasticsearch_password: "your_elasticsearch_password"

# CI/CD Secrets
cicd:
  github_actions:
    secrets:
      DOCKER_REGISTRY_TOKEN: "your_registry_token"
      SLACK_WEBHOOK_URL: "https://hooks.slack.com/services/..."
      DEPLOY_SSH_KEY: |
        -----BEGIN OPENSSH PRIVATE KEY-----
        your_deploy_ssh_key_content_here
        -----END OPENSSH PRIVATE KEY-----

# Application-specific Secrets
applications:
  my_web_app:
    database_url: "postgresql://user:pass@host:5432/db"
    redis_url: "redis://localhost:6379"
    session_secret: "your_session_secret"
    oauth_client_secret: "your_oauth_client_secret"

# Backup and Recovery
backup:
  encryption_passphrase: "your_backup_encryption_passphrase"
  remote_storage_key: "your_remote_storage_access_key"
  gpg_backup_key: |
    -----BEGIN PGP PRIVATE KEY BLOCK-----
    your_backup_gpg_key_content_here
    -----END PGP PRIVATE KEY BLOCK-----