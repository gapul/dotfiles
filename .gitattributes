# SOPS-only Encryption Strategy
# All secrets are managed through SOPS, not Git-crypt

# SOPS encrypted files (allow in repository)
nix/security/sops/*.yaml
nix/security/sops/**/*.yaml

# Exclude example and template files from SOPS encryption
nix/security/sops/*.yaml.example
nix/security/sops/*.yaml.template
*.example
*.template
*.tmpl
*.sample
README.*
SECURITY.*
LICENSE*

# Legacy: These patterns are managed by SOPS now
# (keeping for reference, but all secrets go through SOPS)
# *.key -> managed in SOPS secrets.files.ssh_private_key
# *.pem -> managed in SOPS secrets.files.ssl_certificate  
# .env -> managed in SOPS secrets.env.*
# .ssh/config -> managed in SOPS secrets.files.ssh_config