{
  "mcpServers": {
    "filesystem": {
      "command": "/Users/yuki/.nodebrew/current/bin/npx",
      "args": ["@modelcontextprotocol/server-filesystem", "/Users/yuki/dotfiles"],
      "description": "Secure file operations with configurable access controls for dotfiles management"
    },
    "postgres": {
      "command": "/Users/yuki/.nodebrew/current/bin/npx", 
      "args": ["@modelcontextprotocol/server-postgres", "postgresql://localhost/dotfiles"],
      "description": "PostgreSQL database operations for configuration storage"
    },
    "github": {
      "command": "/Users/yuki/.nodebrew/current/bin/npx",
      "args": ["@modelcontextprotocol/server-github"],
      "description": "GitHub integration for repository management and collaboration",
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": ""
      }
    },
    "brave-search": {
      "command": "/Users/yuki/.nodebrew/current/bin/npx",
      "args": ["@modelcontextprotocol/server-brave-search"],
      "description": "Web and local search capabilities for documentation and troubleshooting",
      "env": {
        "BRAVE_SEARCH_API_KEY": ""
      }
    },
    "figma-dev-mode": {
      "transport": "sse",
      "url": "http://127.0.0.1:3845/sse",
      "description": "Figma Dev Mode integration for design-to-code workflows",
      "requirements": [
        "Figma Desktop app must be running",
        "Dev or Full seat in Professional/Organization/Enterprise plan",
        "MCP server enabled in Figma Dev Mode"
      ]
    },
    "playwright": {
      "command": "/Users/yuki/.nodebrew/current/bin/npx",
      "args": ["@executeautomation/playwright-mcp-server"],
      "description": "Browser automation and web scraping using Playwright",
      "capabilities": [
        "Page navigation and interaction",
        "Element clicking and form filling", 
        "Screenshot capture",
        "Text extraction from web pages",
        "JavaScript execution in browser context"
      ]
    },
    "puppeteer": {
      "command": "/Users/yuki/.nodebrew/current/bin/npx",
      "args": ["@modelcontextprotocol/server-puppeteer"],
      "description": "Browser automation using Puppeteer for web scraping and testing",
      "capabilities": [
        "Headless browser control",
        "Page content extraction",
        "Screenshot and PDF generation",
        "Form automation",
        "Performance monitoring"
      ]
    }
  },
  "installation": {
    "instructions": [
      "1. Install required packages: npm install -g @modelcontextprotocol/server-filesystem @modelcontextprotocol/server-postgres @modelcontextprotocol/server-brave-search @executeautomation/playwright-mcp-server @modelcontextprotocol/server-puppeteer",
      "2. Configure environment variables for GitHub and Brave Search",
      "3. Set up PostgreSQL database if using postgres server",
      "4. Add servers using: claude mcp add <server-name> <command> [args...]",
      "5. Verify installation: claude mcp list"
    ],
    "commands": [
      "claude mcp add filesystem \"npx @modelcontextprotocol/server-filesystem\" \"/Users/yuki/dotfiles\"",
      "claude mcp add postgres \"npx @modelcontextprotocol/server-postgres\" \"postgresql://localhost/dotfiles\"", 
      "claude mcp add github \"npx @modelcontextprotocol/server-github\"",
      "claude mcp add brave-search \"npx @modelcontextprotocol/server-brave-search\"",
      "claude mcp add playwright \"npx @executeautomation/playwright-mcp-server\"",
      "claude mcp add puppeteer \"npx @modelcontextprotocol/server-puppeteer\"",
      "claude mcp add --transport sse figma-dev-mode-mcp-server http://127.0.0.1:3845/sse"
    ]
  },
  "benefits": {
    "filesystem": [
      "Safe file operations within dotfiles directory",
      "Automated configuration file management",
      "Real-time file system monitoring"
    ],
    "postgres": [
      "Database operations for configuration storage",
