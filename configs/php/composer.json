{
  "config": {
    "vendor-dir": "vendor",
    "bin-dir": "vendor/bin",
    "cache-dir": "~/.composer/cache",
    "optimize-autoloader": true,
    "classmap-authoritative": false,
    "apcu-autoloader": false,
    "platform-check": true,
    "sort-packages": true,
    "allow-plugins": {
      "*": false
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://packagist.org"
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true
}