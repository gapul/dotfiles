[user]
    name = Your Name
    email = your.email@example.com

[core]
    editor = vim
    autocrlf = input

[push]
    default = simple

[pull]
    rebase = false

[init]
    defaultBranch = main

[alias]
    st = status
    co = checkout
    br = branch
    ci = commit
    lg = log --oneline --graph