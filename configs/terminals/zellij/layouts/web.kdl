// Web Development Layout for Zellij
// Optimized for modern web development workflow

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="Editor" focus=true {
        pane {
            name "editor"
        }
    }
    
    tab name="Server" {
        pane split_direction="vertical" {
            pane {
                name "dev-server"
                command "bash"
                args "-c" "echo 'Run: npm run dev or similar command'; exec bash"
            }
            pane size="40%" {
                name "build-logs"
                command "bash"
                args "-c" "echo 'Build logs will appear here'; exec bash"
            }
        }
    }
    
    tab name="Terminal" {
        pane split_direction="vertical" {
            pane {
                name "main-terminal"
            }
            pane size="30%" {
                name "quick-commands"
                command "bash"
                args "-c" "echo 'Quick commands: npm install, npm test, etc.'; exec bash"
            }
        }
    }
    
    tab name="Git" {
        pane command="lazygit" {
            name "git-ui"
        }
    }
    
    tab name="Browser" {
        pane split_direction="vertical" {
            pane {
                name "dev-tools"
                command "bash"
                args "-c" "echo 'Open browser dev tools here or use browser sync'; exec bash"
            }
            pane size="40%" {
                name "api-test"
                command "bash"
                args "-c" "echo 'API testing: curl, httpie, etc.'; exec bash"
            }
        }
    }
    
    tab name="Files" {
        pane command="yazi" {
            name "file-manager"
        }
    }
}