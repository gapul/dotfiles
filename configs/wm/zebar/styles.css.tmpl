/* Zebar styles - Rose Pine theme (Mac SketchyBar と統一)
 * 配置先: %USERPROFILE%\.glzr\zebar\styles.css (bootstrap.ps1 で symlink)
 *
 * 元: Zebar starter pack の Tokyo Night
 * 変更: Rose Pine palette + SketchyBar 風の widget pill レイアウト
 *       (バー本体は半透明、個別 widget が背景 pill を持つ)
 */
@import 'https://www.nerdfonts.com/assets/css/webfont.css';

:root {
  /* Palette は configs/theme/palettes.json から render される (SSO)。 */
  --rp-base:    {{ palette.base }};
  --rp-surface: {{ palette.surface }};
  --rp-overlay: {{ palette.overlay }};
  --rp-muted:   {{ palette.muted }};
  --rp-subtle:  {{ palette.subtle }};
  --rp-text:    {{ palette.text }};
  --rp-love:    {{ palette.love }};
  --rp-gold:    {{ palette.gold }};
  --rp-rose:    {{ palette.rose }};
  --rp-pine:    {{ palette.pine }};
  --rp-foam:    {{ palette.foam }};
  --rp-iris:    {{ palette.iris }};

  /* UI alias (color-mix で alpha 合成 → palette 変更で自動追従) */
  --bg:         color-mix(in srgb, var(--rp-base) 88%, transparent);
  --bg-widget:  color-mix(in srgb, var(--rp-overlay) 75%, transparent);
  --text:       var(--rp-text);
  --text-dim:   var(--rp-subtle);
  --accent:     var(--rp-iris);
  --border:     color-mix(in srgb, var(--rp-iris) 12%, transparent);
  --ws-active:  color-mix(in srgb, var(--rp-iris) 25%, transparent);
  --ws-focus:   color-mix(in srgb, var(--rp-iris) 55%, transparent);
  --font-size:  12px;
}

body {
  /* テキストは可読性優先 (HackGen 系 → M+Code Nerd → SF Pro)。
     Nerd Symbols は `i` 要素で別フォント指定するので body は通常テキスト系で OK。 */
  font-family: 'HackGen Console NF', 'M+CodeLat50NerdFont',
               'JetBrainsMono Nerd Font', 'SF Pro Display',
               'Yu Gothic UI', ui-monospace, sans-serif;
  font-size: var(--font-size);
  color: var(--text);
  overflow: hidden;
}

div, span, p {
  cursor: default;
  user-select: none;
}

html, body, #root {
  height: 100%;
}

#root {
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  /* SketchyBar 風の薄いシャドウ */
  box-shadow: 0 2px 8px rgba(0 0 0 / 30%);
}

i {
  /* HackGen Console NF は Nerd Font 版で icon glyph 含むので 1st で OK。
     M+Code / JetBrainsMono Nerd / Symbols Nerd Font に fallback。
     大きめ + 縦中央寄せで視認性確保。 */
  font-family: 'HackGen Console NF', 'M+CodeLat50NerdFont',
               'M+CodeLat60NerdFont', 'JetBrainsMono Nerd Font',
               'Symbols Nerd Font Mono', monospace;
  font-style: normal;
  margin-right: 6px;
  font-size: calc(var(--font-size) * 1.15);
  line-height: 1;
  color: var(--accent);
  vertical-align: middle;
  display: inline-flex;
  align-items: center;
}

.app {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  align-items: center;
  height: 100%;
  padding: 4px 1.5vw;
}

.left, .center, .right {
  display: flex;
  align-items: center;
  gap: 8px;
}

.center { justify-self: center; }
.right  { justify-self: end; }

.logo {
  color: var(--accent);
  margin-right: 4px;
}

.workspaces {
  display: flex;
  align-items: center;
  gap: 4px;
}

.workspace {
  background: var(--bg-widget);
  padding: 2px 10px;
  color: var(--text-dim);
  border: 1px solid transparent;
  border-radius: 4px;
  cursor: pointer;
  font-size: var(--font-size);
  font-family: inherit;
  transition: background 0.15s, color 0.15s, border-color 0.15s;

  &.displayed {
    background: var(--ws-active);
    color: var(--text);
  }

  &.focused, &:hover {
    background: var(--ws-focus);
    color: var(--rp-base);
    border-color: var(--accent);
  }
}

.binding-mode, .tiling-direction, .paused-button {
  background: var(--bg-widget);
  color: var(--text);
  border-radius: 4px;
  border: 1px solid var(--border);
  padding: 2px 8px;
  cursor: pointer;
  font-family: inherit;
  font-size: var(--font-size);
}

.network, .memory, .cpu, .battery, .weather {
  display: flex;
  align-items: center;
}

.cpu .high-usage {
  color: var(--rp-love);   /* 高負荷時は Love (red 系) */
}

.battery {
  position: relative;
}

.battery .charging-icon {
  position: absolute;
  font-size: 7px;
  left: -8px;
  top: 3px;
  color: var(--rp-foam);   /* 充電中は Foam (cyan 系) */
}
