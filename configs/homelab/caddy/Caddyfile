# gapul.net リバースプロキシ (Tailscale限定・LE証明書はCloudflare DNS-01)
home.gapul.net {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
	reverse_proxy 192.168.116.88:8123 {
		header_up -X-Forwarded-For
	}
}

dockge.gapul.net {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
	reverse_proxy 192.168.116.65:5001
}

pve.gapul.net {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
	reverse_proxy https://192.168.116.100:8006 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}

