#!/usr/bin/env bash
# ghq + fzf のプレビュー: git 状態 + README優先 (無ければツリー)
set -euo pipefail

repo="$1"
[[ -d "$repo" ]] || exit 0

# git の状態 (ブランチ / 変更有無 / 最終コミット)
if [[ -d "$repo/.git" ]]; then
  branch=$(git -C "$repo" symbolic-ref --short HEAD 2>/dev/null || echo "?")
  dirty=$(git -C "$repo" status --porcelain 2>/dev/null | head -1)
  last=$(git -C "$repo" log -1 --format='%cr  %s' 2>/dev/null || echo "-")
  printf '\033[1;34m %s\033[0m  %s\n' "$branch" "${dirty:+● uncommitted}"
  printf '\033[2m%s\033[0m\n' "$last"
  printf '%s\n' "────────────────────────────────────"
fi

# README があれば表示、無ければファイルツリー
readme=$(find "$repo" -maxdepth 1 -iname 'readme*' | head -1)
if [[ -n "$readme" ]]; then
  bat --color=always --style=plain --line-range=:60 "$readme"
else
  eza --tree --level=2 --color=always --icons "$repo"
fi
