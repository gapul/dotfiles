# Go environment configuration for Nix integration
# Source this file or set these variables in your shell

# Go workspace (following Go 1.11+ module system)
export GOPATH="$HOME/go"
export GOBIN="$GOPATH/bin"

# Go module settings
export GO111MODULE=on
export GOPROXY=https://proxy.golang.org,direct
export GOSUMDB=sum.golang.org

# Go build settings
export CGO_ENABLED=1
export GOARCH=arm64  # Adjust for your architecture
export GOOS=darwin   # Adjust for your OS

# Development settings
export GODEBUG=gctrace=1  # Uncomment for GC tracing
export GOTRACEBACK=all    # Full stack traces

# Private module settings (uncomment if needed)
# export GOPRIVATE=github.com/yourorg/*
# export GONOPROXY=github.com/yourorg/*
# export GONOSUMDB=github.com/yourorg/*

# Go tools
export PATH="$GOBIN:$PATH"