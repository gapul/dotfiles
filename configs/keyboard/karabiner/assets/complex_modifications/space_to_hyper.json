{
  "title": "Space to Cmd+Ctrl+Opt (Meh)",
  "rules": [
    {
      "description": "スペースキーを単押しでスペース、長押しでCmd+Ctrl+Optにする",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "spacebar",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_control",
              "modifiers": [
                "left_command",
                "left_option"
              ]
            }
          ],
          "to_if_alone": [
            {
              "key_code": "spacebar"
            }
          ]
        }
      ]
    }
  ]
}
