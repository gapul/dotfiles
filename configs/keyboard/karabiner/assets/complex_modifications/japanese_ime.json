{
  "title": "Japanese IME & Emacs Keybindings",
  "rules": [
    {
      "description": "Input Mode Switch (Ctrl+Shift)",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "j", "modifiers": { "mandatory": [ "control", "shift" ] } },
          "to": [ { "key_code": "japanese_kana" } ]
        },
        {
          "type": "basic",
          "from": { "key_code": "semicolon", "modifiers": { "mandatory": [ "control", "shift" ] } },
          "to": [ { "key_code": "japanese_eisuu" } ]
        },
        {
          "type": "basic",
          "from": { "key_code": "r", "modifiers": { "mandatory": [ "control", "shift" ] } },
          "to": [ { "key_code": "japanese_kana" } ]
        }
      ]
    },
    {
      "description": "Character Conversion (Ctrl)",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "j", "modifiers": { "mandatory": [ "control" ] } },
          "to": [ { "shell_command": "osascript -e 'tell application \"System Events\" to key code 103'" } ]
        },
        {
          "type": "basic",
          "from": { "key_code": "k", "modifiers": { "mandatory": [ "control" ] } },
          "to": [ { "shell_command": "osascript -e 'tell application \"System Events\" to key code 98'" } ]
        },
        {
          "type": "basic",
          "from": { "key_code": "l", "modifiers": { "mandatory": [ "control" ] } },
          "to": [ { "shell_command": "osascript -e 'tell application \"System Events\" to key code 101'" } ]
        },
        {
          "type": "basic",
          "from": { "key_code": "semicolon", "modifiers": { "mandatory": [ "control" ] } },
          "to": [ { "shell_command": "osascript -e 'tell application \"System Events\" to key code 109'" } ]
        }
      ]
    },
    {
      "description": "Emacs Style Keybindings (Ctrl)",
      "manipulators": [
        { "type": "basic", "from": { "key_code": "a", "modifiers": { "mandatory": [ "control" ] } }, "to": [ { "key_code": "home" } ] },
        { "type": "basic", "from": { "key_code": "e", "modifiers": { "mandatory": [ "control" ] } }, "to": [ { "key_code": "end" } ] },
        { "type": "basic", "from": { "key_code": "f", "modifiers": { "mandatory": [ "control" ] } }, "to": [ { "key_code": "right_arrow" } ] },
        { "type": "basic", "from": { "key_code": "b", "modifiers": { "mandatory": [ "control" ] } }, "to": [ { "key_code": "left_arrow" } ] },
        { "type": "basic", "from": { "key_code": "n", "modifiers": { "mandatory": [ "control" ] } }, "to": [ { "key_code": "down_arrow" } ] },
        { "type": "basic", "from": { "key_code": "p", "modifiers": { "mandatory": [ "control" ] } }, "to": [ { "key_code": "up_arrow" } ] },
        { "type": "basic", "from": { "key_code": "h", "modifiers": { "mandatory": [ "control" ] } }, "to": [ { "key_code": "delete_or_backspace" } ] },
        { "type": "basic", "from": { "key_code": "d", "modifiers": { "mandatory": [ "control" ] } }, "to": [ { "key_code": "delete_forward" } ] }
      ]
    }
  ]
}