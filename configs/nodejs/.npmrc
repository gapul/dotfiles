# NPM configuration for Nix integration
# This configuration ensures npm works properly with Nix-managed Node.js

# Use Nix-managed npm registry
registry=https://registry.npmjs.org/

# Disable package-lock for better Nix integration
package-lock=false

# Prefer offline (use Nix store when possible)
prefer-offline=true

# Security settings
audit-level=moderate
fund=false

# Performance settings
maxsockets=15
timeout=300000

# Development settings
save-exact=true
save-prefix=""

# Disable npm update notifications (Nix handles updates)
update-notifier=false

# Use local .npmrc in projects for project-specific settings