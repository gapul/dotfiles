# ===========================================
# Next.js Fullstack Application Environment
# ===========================================

# Application Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/{{PROJECT_NAME}}_dev?schema=public"

# NextAuth.js Configuration
NEXTAUTH_SECRET=your-nextauth-secret-change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email Configuration (Resend)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@yourdomain.com

# File Upload (UploadThing)
UPLOADTHING_SECRET=your-uploadthing-secret
UPLOADTHING_APP_ID=your-uploadthing-app-id

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Stripe Product IDs
STRIPE_PRO_MONTHLY_PRICE_ID=price_your-pro-monthly-price-id
STRIPE_PRO_YEARLY_PRICE_ID=price_your-pro-yearly-price-id

# Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VERCEL_ANALYTICS_ID=your-vercel-analytics-id

# Error Tracking (Optional)
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=your-public-sentry-dsn

# Feature Flags (Optional)
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_PAYMENTS=false
NEXT_PUBLIC_ENABLE_BLOG=true

# Rate Limiting (Optional)
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Content Management (Optional)
SANITY_PROJECT_ID=your-sanity-project-id
SANITY_DATASET=production
SANITY_API_VERSION=2023-12-01
SANITY_API_TOKEN=your-sanity-api-token

# Search (Optional - Algolia)
NEXT_PUBLIC_ALGOLIA_APP_ID=your-algolia-app-id
ALGOLIA_ADMIN_API_KEY=your-algolia-admin-key
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=your-algolia-search-key

# Image Optimization (Optional - Cloudinary)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Social Media Integration (Optional)
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
DISCORD_WEBHOOK_URL=your-discord-webhook-url

# Development Tools
ANALYZE=false
DISABLE_ESLINT=false
DISABLE_TYPE_CHECK=false

# Testing Configuration
TEST_DATABASE_URL="postgresql://postgres:password@localhost:5432/{{PROJECT_NAME}}_test?schema=public"

# Production Environment Variables (uncomment for production)
# NODE_ENV=production
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# NEXTAUTH_URL=https://yourdomain.com
# DATABASE_URL="postgresql://username:password@host:port/database?schema=public"