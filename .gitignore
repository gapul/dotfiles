# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Backup files
backups/

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Node.js (npm/yarn dependencies should be managed by Nix)
node_modules/
package.json
package-lock.json
yarn.lock
.npm/
.yarn/

# IDE
.vscode/
.idea/

# Logs
*.log

# System files
*.orig

# SOPS Unified Encryption Strategy
# All secrets now managed through SOPS - most .gitignore patterns no longer needed

# Legacy sensitive configuration files (gradually migrating to SOPS)
configs/git/.gitconfig
configs/ssh/config
configs/apps/claude/claude.json

# SOPS encrypted files (these SHOULD be in repository)
!nix/security/sops/secrets-unified.yaml

# Only exclude unencrypted secrets (emergency fallback)
*.env.local
**/api_key_unencrypted*
**/token_unencrypted*

# Allow example and template files
!*.example
!*.template
!*.sample

# Legacy patterns (most secrets now in SOPS)
# *.key -> now in SOPS secrets.ssh.private_key
# *.pem -> now in SOPS secrets.ssl.certificate
# secrets.* -> now encrypted in secrets-unified.yaml
# .env -> now in SOPS secrets.development.env_vars

# User-specific data that shouldn't be shared
configs/**/user_data/
configs/**/cache/
configs/**/sessions/